{
  "name": "chess-dev",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "dev",
  "workspaceFolder": "/workspaces/chess",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/chess,type=bind",
  "runArgs": [
    "--network=host",
    "--privileged",
    "-v",
    "/dev/bus/usb:/dev/bus/usb"
  ],
  "containerEnv": {
    "ANDROID_HOME": "/home/dev/Android/Sdk",
    "ANDROID_NDK_HOME": "/home/dev/Android/Sdk/ndk/28.2.13676358"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "postCreateCommand": "flutter pub get && (cd rust && cargo fetch)"
}
