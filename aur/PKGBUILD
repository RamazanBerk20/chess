# Maintainer: Ramazan Berk Şirin <ramazanberksirin@protonmail.com>
pkgname=satranc-bin
pkgver=1.0.0
pkgrel=1
pkgdesc="Chess with variants (Fog of War, Bughouse, 4-player, Crazyhouse, Atomic…), AI, LAN and puzzles — Flutter + Rust"
arch=('x86_64')
url="https://github.com/RamazanBerk20/chess"
license=('MIT')
depends=('gtk3')
provides=('satranc')
conflicts=('satranc')
options=('!strip' '!debug')
source=("chess-$pkgver-linux-x86_64.tar.gz::$url/releases/download/v$pkgver/chess-$pkgver-linux-x86_64.tar.gz"
        "satranc-$pkgver.png::$url/raw/v$pkgver/assets/icon/chess.png"
        "LICENSE-$pkgver::$url/raw/v$pkgver/LICENSE")
sha256sums=('SKIP'
            'SKIP'
            'SKIP')

package() {
  # Flutter bundle (binary + data/ + lib/) lives at the tarball root.
  install -dm755 "$pkgdir/opt/satranc"
  cp -dr --no-preserve=ownership "$srcdir/chess" "$srcdir/data" "$srcdir/lib" \
    "$pkgdir/opt/satranc/"
  chmod 755 "$pkgdir/opt/satranc/chess"

  install -dm755 "$pkgdir/usr/bin"
  ln -s /opt/satranc/chess "$pkgdir/usr/bin/satranc"

  install -Dm644 "$srcdir/satranc-$pkgver.png" \
    "$pkgdir/usr/share/icons/hicolor/512x512/apps/satranc.png"
  install -Dm644 "$srcdir/LICENSE-$pkgver" \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  install -dm755 "$pkgdir/usr/share/applications"
  cat > "$pkgdir/usr/share/applications/satranc.desktop" <<'EOF'
[Desktop Entry]
Type=Application
Name=Satranç
GenericName=Chess
Comment=Chess with variants, AI, LAN and puzzles
Exec=satranc
Icon=satranc
Terminal=false
Categories=Game;BoardGame;
EOF
}
